<section class="auth-visual">
  <span class="auth-visual__eyebrow"><%= eyebrow %></span>

  <div class="auth-visual__content">
    <h2 class="auth-visual__title"><%= title %></h2>
    <p class="auth-visual__description"><%= description %></p>
  </div>

  <div class="auth-visual__media" aria-hidden="true">
    <div class="auth-visual__media-card auth-visual__media-card--primary">
      <%= image_tag "Screenshot from 2026-04-15 10-28-29.png",
                    class: "auth-visual__media-image",
                    alt: "" %>
    </div>

    <div class="auth-visual__media-card auth-visual__media-card--secondary">
      <%= image_tag "Screenshot from 2026-04-15 10-28-38.png",
                    class: "auth-visual__media-image",
                    alt: "" %>
    </div>
  </div>

  <div class="auth-visual__footer">
    <div class="auth-visual__card">
      <span>Quarterly Flow</span>
      <strong>Goals, reviews, and approvals stay aligned.</strong>
    </div>

    <div class="auth-visual__card">
      <span>Built For Teams</span>
      <strong><%= footer_copy %></strong>
    </div>
  </div>
</section>

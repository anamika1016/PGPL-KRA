<section class="auth-visual">
  <span class="auth-visual__eyebrow"><%= eyebrow %></span>

  <div class="auth-visual__content">
    <h2 class="auth-visual__title"><%= title %></h2>
    <p class="auth-visual__description"><%= description %></p>
  </div>

  <div class="auth-visual__art" aria-hidden="true">
    <div class="auth-visual__halo"></div>

    <div class="auth-visual__dashboard">
      <div class="auth-visual__dashboard-top">
        <span></span>
        <span></span>
        <span></span>
      </div>

      <div class="auth-visual__metric">
        <strong>75%</strong>
        <span>KRA weightage in one focused workspace</span>
      </div>

      <div class="auth-visual__bars">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>

    <div class="auth-visual__chip auth-visual__chip--top">Pulse 15%</div>
    <div class="auth-visual__chip auth-visual__chip--bottom">Manager 10%</div>
  </div>

  <div class="auth-visual__footer">
    <div class="auth-visual__card">
      <span>Quarterly Flow</span>
      <strong>Goals, reviews, and approvals stay aligned.</strong>
    </div>

    <div class="auth-visual__card">
      <span>Built For Teams</span>
      <strong><%= footer_copy %></strong>
    </div>
  </div>
</section>

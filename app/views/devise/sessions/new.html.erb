<div class="auth-shell">
  <%= render "devise/shared/auth_showcase",
             eyebrow: "Welcome Back",
             title: "One calm place for goals, reviews, and approvals.",
             description: "Sign in to continue your KRA workflow with the same logic and access you already use today.",
             footer_copy: "Built around the KRA 75%, Pulse 15%, and Manager 10% scoring model." %>

  <section class="auth-panel">
    <span class="auth-panel__eyebrow">Sign In</span>
    <h1 class="auth-panel__title">Welcome back</h1>
    <p class="auth-panel__description">
      Enter your account details to open your dashboard and continue tracking quarterly performance.
    </p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form", data: { turbo: false } }) do |f| %>
      <div class="auth-field">
        <%= f.label :email, class: "auth-field__label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-field__control", placeholder: "name@company.com" %>
      </div>

      <div class="auth-field">
        <%= f.label :password, class: "auth-field__label" %>
        <div class="auth-password" data-controller="password-toggle">
          <%= f.password_field :password,
                               autocomplete: "current-password",
                               class: "auth-field__control auth-password__input",
                               placeholder: "Enter your password",
                               data: { password_toggle_target: "input" } %>
          <button type="button"
                  class="auth-password__toggle"
                  data-action="password-toggle#toggle"
                  aria-label="Toggle password visibility">
            <span class="auth-password__toggle-label sr-only" data-password-toggle-target="label">Show password</span>
            <svg class="auth-password__icon" data-password-toggle-target="showIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M2 12s3.6-6 10-6 10 6 10 6-3.6 6-10 6S2 12 2 12Z" />
              <circle cx="12" cy="12" r="3" />
            </svg>
            <svg class="auth-password__icon" data-password-toggle-target="hideIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" hidden>
              <path d="M3 3l18 18" />
              <path d="M10.6 10.7a3 3 0 0 0 4.1 4.1" />
              <path d="M9.9 5.1A11 11 0 0 1 12 5c6.4 0 10 7 10 7a18.7 18.7 0 0 1-4.2 4.8" />
              <path d="M6.6 6.7A18.2 18.2 0 0 0 2 12s3.6 7 10 7a10.7 10.7 0 0 0 4-.8" />
            </svg>
          </button>
        </div>
      </div>

      <div class="auth-field">
        <%= f.label :employee_code, "Employee Code", class: "auth-field__label" %>
        <%= f.text_field :employee_code, class: "auth-field__control", placeholder: "Enter your employee code" %>
      </div>

      <div class="auth-form__meta">
        <% if devise_mapping.rememberable? %>
          <label class="auth-check">
            <%= f.check_box :remember_me %>
            <span>Keep me signed in</span>
          </label>
        <% else %>
          <span></span>
        <% end %>

        <% if devise_mapping.recoverable? %>
          <%= link_to "Forgot password?", new_password_path(resource_name), class: "auth-link" %>
        <% end %>
      </div>

      <%= f.submit "Log in", class: "auth-button" %>
    <% end %>

    <p class="auth-panel__switch">
      Need an account?
      <%= link_to "Sign up", new_registration_path(resource_name), class: "auth-link" %>
    </p>
  </section>
</div>

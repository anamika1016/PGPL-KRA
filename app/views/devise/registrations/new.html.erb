<div class="auth-shell">
  <%= render "devise/shared/auth_showcase",
             eyebrow: "Create Account",
             title: "Set up access for focused performance tracking.",
             description: "Use the same registration flow you already have, now wrapped in a cleaner and more polished sign-up experience.",
             footer_copy: "Invite new employees and HOD users into the same shared scoring system." %>

  <section class="auth-panel">
    <span class="auth-panel__eyebrow">Sign Up</span>
    <h1 class="auth-panel__title">Create your account</h1>
    <p class="auth-panel__description">
      Register a new profile to start submitting, reviewing, and managing KRA activity in one place.
    </p>

    <% if resource.errors.any? %>
      <div class="auth-inline-message" role="alert">
        <ul>
          <% resource.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form", autocomplete: "off", data: { turbo: false } }) do |f| %>
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

      <div class="auth-field">
        <%= f.label :email, "Email", class: "auth-field__label" %>
        <%= f.email_field :email, autofocus: true, required: true, autocomplete: "email", placeholder: "name@company.com", class: "auth-field__control" %>
      </div>

      <div class="auth-form__row">
        <div class="auth-field">
          <%= f.label :employee_code, "Employee Code", class: "auth-field__label" %>
          <%= f.text_field :employee_code, required: true, placeholder: "Enter employee code", class: "auth-field__control" %>
        </div>

        <div class="auth-field">
          <%= f.label :role, "Role", class: "auth-field__label" %>
          <%= f.select :role, [["Employee", "employee"], ["HOD", "hod"]], { prompt: "Choose your role" }, class: "auth-field__control", required: true %>
        </div>
      </div>

      <div class="auth-form__row">
        <div class="auth-field">
          <%= f.label :password, "Password", class: "auth-field__label" %>
          <%= f.password_field :password, required: true, autocomplete: "new-password", placeholder: "Create a password", class: "auth-field__control" %>
          <% if @minimum_password_length %>
            <p class="auth-password-hint">Use at least <%= @minimum_password_length %> characters.</p>
          <% end %>
        </div>

        <div class="auth-field">
          <%= f.label :password_confirmation, "Confirm Password", class: "auth-field__label" %>
          <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Confirm password", class: "auth-field__control" %>
        </div>
      </div>

      <%= f.submit "Create account", class: "auth-button" %>
    <% end %>

    <p class="auth-panel__switch">
      Already have an account?
      <%= link_to "Sign in", new_session_path(resource_name), class: "auth-link" %>
    </p>
  </section>
</div>

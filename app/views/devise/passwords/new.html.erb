<div class="forgot-password-shell">
  <div class="forgot-password-card">
    <div class="forgot-password-hero">
      <span class="forgot-password-kicker">Account Recovery</span>
      <h1>Forgot Your Password?</h1>
      <p>Enter your registered email address and we will send reset instructions to help you get back into your PGPL account.</p>
    </div>

    <div class="forgot-password-form-wrap">
      <% if resource.errors.any? %>
        <div class="forgot-password-alert" role="alert">
          <strong>Please check the form:</strong>
          <ul>
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, data: { turbo: false }, class: "forgot-password-form" }) do |f| %>
        <div class="forgot-password-field">
          <%= f.label :email, "Registered Email", class: "forgot-password-label" %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "forgot-password-input",
              placeholder: "name@company.com" %>
        </div>

        <%= f.submit "Send Reset Instructions", class: "forgot-password-submit" %>
      <% end %>

      <div class="forgot-password-links">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>

<style>
  .forgot-password-shell {
    min-height: calc(100vh - 3rem);
    display: grid;
    place-items: center;
    padding: 2rem 1rem;
  }

  .forgot-password-card {
    width: min(100%, 980px);
    display: grid;
    grid-template-columns: minmax(280px, 1.1fr) minmax(320px, 0.9fr);
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(210, 227, 216, 0.9);
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 28px 70px rgba(18, 56, 77, 0.14);
  }

  .forgot-password-hero {
    padding: 3rem;
    background:
      radial-gradient(circle at top left, rgba(91, 176, 117, 0.22), transparent 32%),
      linear-gradient(145deg, #12384d 0%, #1f6b45 100%);
    color: #f5fbf7;
  }

  .forgot-password-kicker {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .forgot-password-hero h1 {
    margin: 0 0 0.9rem;
    font-size: clamp(2rem, 3vw, 2.8rem);
    line-height: 1.08;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .forgot-password-hero p {
    margin: 0;
    max-width: 34rem;
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(245, 251, 247, 0.88);
  }

  .forgot-password-form-wrap {
    padding: 3rem 2.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.25rem;
    background: linear-gradient(180deg, #ffffff 0%, #f8fcf8 100%);
  }

  .forgot-password-alert {
    padding: 1rem 1rem 0.9rem;
    border-radius: 18px;
    border: 1px solid #f4c7cd;
    background: #fff2f4;
    color: #8f2230;
    font-size: 0.95rem;
  }

  .forgot-password-alert strong {
    display: block;
    margin-bottom: 0.4rem;
  }

  .forgot-password-alert ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .forgot-password-form {
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
  }

  .forgot-password-field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .forgot-password-label {
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #335347;
  }

  .forgot-password-input {
    width: 100%;
    padding: 1rem 1.05rem;
    border: 1px solid #d3e3d7;
    border-radius: 18px;
    background: #ffffff;
    color: #143728;
    font-size: 1rem;
    box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.04);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .forgot-password-input:focus {
    outline: none;
    border-color: #2b7a4b;
    box-shadow: 0 0 0 4px rgba(65, 143, 93, 0.14);
    transform: translateY(-1px);
  }

  .forgot-password-submit {
    width: 100%;
    padding: 1rem 1.2rem;
    border: none;
    border-radius: 18px;
    background: linear-gradient(135deg, #1a6d45 0%, #12384d 100%);
    color: #ffffff;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    box-shadow: 0 18px 40px rgba(18, 56, 77, 0.2);
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
  }

  .forgot-password-submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 22px 44px rgba(18, 56, 77, 0.24);
    opacity: 0.98;
  }

  .forgot-password-links {
    padding-top: 0.25rem;
    border-top: 1px solid #e6f0e8;
  }

  .forgot-password-links a {
    color: #17553a;
    font-weight: 600;
    text-decoration: none;
  }

  .forgot-password-links a:hover {
    color: #12384d;
  }

  @media (max-width: 860px) {
    .forgot-password-card {
      grid-template-columns: 1fr;
    }

    .forgot-password-hero,
    .forgot-password-form-wrap {
      padding: 2rem 1.4rem;
    }
  }
</style>
